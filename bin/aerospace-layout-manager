#!/bin/bash

# AeroSpace Layout Manager
# Recreates a layout from aerospace tree JSON output
#
# Usage:
#   ./aerospace-layout-manager <workspace> <json_file>
#   ./aerospace-layout-manager <workspace> < layout.json
#   aerospace tree --workspace temp | ./aerospace-layout-manager <workspace>

set -euo pipefail

# =============================================================================
# INITIALIZATION
# =============================================================================

# Determine script location and source library modules
# Use readlink -f to resolve symlinks, so lib/ is found even when script is symlinked
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
LIB_DIR="$(cd "$SCRIPT_DIR/../lib" && pwd)"

# Source all modules
source "$LIB_DIR/init.sh"

# =============================================================================
# MAIN
# =============================================================================

usage() {
    cat <<EOF
Usage:
  $0 [--allow-missing] <target_workspace> [json_file]   (apply, default)
  $0 verify <target_workspace> <json_file>              (diff only, no apply)
  $0 apply-verify [--allow-missing] <target_workspace> <json_file>
                                                         (apply, then diff)

Stdin is accepted in place of json_file for the default apply mode.
EOF
}

# Run the structural comparison against the live aerospace tree. Reuses
# normalize_layout_tree so the baseline matches what the apply pipeline
# would build -- any divergence is an aerospace-side or apply-side bug.
#
# Arguments: <workspace> <definition_json>
# Returns: 0 match, 1 mismatch, 2 query/normalize error
run_verify() {
    local workspace="$1"
    local definition_json="$2"

    local root_container
    root_container=$(get_root_container "$definition_json")
    if [[ -z "$root_container" || "$root_container" == "null" ]]; then
        error "No root-container found in definition"
        return 2
    fi

    root_container=$(normalize_layout_tree "$root_container")

    # Wrap normalized root back in workspace-array shape so build_expected_structure
    # (which starts from .[0] and descends into root-container) can consume it.
    local expected_wrapped
    expected_wrapped=$(jq -n --argjson root "$root_container" \
        '[{type:"workspace", "root-container": $root}]')

    local actual_tree
    actual_tree=$(aerospace tree --json --workspace "$workspace" 2>/dev/null || echo "")
    if [[ -z "$actual_tree" ]]; then
        error "Failed to query live aerospace tree for workspace $workspace"
        return 2
    fi

    log "Comparing definition against live tree for workspace: $workspace"
    if compare_tree_structure "$expected_wrapped" "$actual_tree"; then
        log "Tree structures match ✓"
        return 0
    fi
    return 1
}

main() {
    check_dependencies

    # Detect subcommand (optional first positional)
    local subcommand="apply"
    case "${1:-}" in
        verify|apply-verify)
            subcommand="$1"
            shift
            ;;
        -h|--help|help)
            usage
            exit 0
            ;;
    esac

    local target_workspace=""
    local json_input=""
    ALLOW_MISSING=0

    # Parse flags
    while [[ $# -gt 0 && "$1" == --* ]]; do
        case "$1" in
            --allow-missing)
                ALLOW_MISSING=1
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                error "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    # Parse positional arguments
    if [[ $# -lt 1 ]]; then
        usage
        exit 1
    fi

    target_workspace="$1"

    if [[ $# -ge 2 ]]; then
        # JSON file provided as argument
        if [[ ! -f "$2" ]]; then
            error "File not found: $2"
            exit 1
        fi
        json_input=$(cat "$2")
    elif [[ "$subcommand" == "verify" ]]; then
        error "verify requires a layout JSON file (stdin not supported)"
        exit 1
    else
        # Read from stdin
        if [[ -t 0 ]]; then
            error "No JSON input provided. Pipe JSON or provide file path."
            exit 1
        fi
        json_input=$(cat)
    fi

    # Validate JSON
    if ! echo "$json_input" | jq empty 2>/dev/null; then
        error "Invalid JSON input"
        exit 1
    fi

    # verify-only: compare without applying
    if [[ "$subcommand" == "verify" ]]; then
        run_verify "$target_workspace" "$json_input"
        exit $?
    fi

    log "=========================================="
    log "AeroSpace Layout from Dump-Tree"
    log "=========================================="
    log "Target workspace: $target_workspace"
    log "Temp workspace: $TEMP_WORKSPACE"

    # Get root container
    local root_container
    root_container=$(get_root_container "$json_input")

    if [[ -z "$root_container" ]] || [[ "$root_container" == "null" ]]; then
        error "No root-container found in dump"
        exit 1
    fi

    # Pre-normalize the layout tree (AeroSpace normalization rules)
    debug "Pre-normalizing layout tree..."
    root_container=$(normalize_layout_tree "$root_container")

    local root_layout
    root_layout=$(echo "$root_container" | jq -r '.layout // "tiles"')
    log "Root layout: $root_layout"

    # Step 1: Clear ALL windows from target workspace to temp (MUST be first!)
    clear_workspace_to_temp "$target_workspace"

    # Step 2: Create window mapping (find all windows from dump)
    local mapping
    mapping=$(create_window_mapping "$root_container")

    local window_count
    window_count=$(echo "$mapping" | jq 'length')
    log "Found $window_count windows"

    # Step 3: Move dump windows to temp (in case they're on other workspaces)
    clear_dump_windows_to_temp "$mapping"

    # Step 4: Switch to target workspace
    log "Switching to workspace: $target_workspace"
    aerospace_workspace "$target_workspace"

    # Step 5: Move all windows to target workspace
    move_windows_to_workspace "$root_container" "$mapping" "$target_workspace"

    # Step 6: Flatten workspace and set root layout
    # This ensures all windows are at the same level before we start grouping
    log "Flattening workspace and setting root layout: $root_layout"
    aerospace_flatten_workspace_tree --workspace "$target_workspace"

    # Focus any window in the workspace and set root layout
    local any_window
    any_window=$(echo "$mapping" | jq -r 'to_entries[0].value // empty')
    if [[ -n "$any_window" ]]; then
        aerospace_focus --window-id "$any_window"
        aerospace_layout "$root_layout"
    fi

    # Step 6b: Reorder windows to match layout tree DFS order
    # After flatten, windows may not be in the correct spatial order.
    # Phase 1 relies on spatial adjacency for join-with, so we must
    # ensure windows are ordered left-to-right (h_*) or top-to-bottom (v_*)
    # matching the DFS traversal of the layout tree.
    log "Reordering windows to match layout tree order..."
    reorder_windows_to_dfs "$root_container" "$mapping" "$target_workspace"

    # Step 7: Apply layout operations in two phases
    # Phase 1: Create all nested containers via joins
    # Pass root_layout so all joins use the correct spatial arrangement
    # Pass is_root=true for the root container so it doesn't try to join its children
    log "Phase 1: Creating nested containers..."
    apply_layout "$root_container" "$mapping" "$target_workspace" "$root_layout" "true"

    # Step 7a: Re-apply root layout after Phase 1
    # aerospace_layout targets the PARENT container of the focused window.
    # After Phase 1, some windows may be inside nested containers, so we
    # must find a window that's still at root level. If ALL windows are
    # in nested containers, we temporarily move one to root level.
    log "Re-applying root layout after Phase 1: $root_layout"
    set_root_layout "$root_layout" "$target_workspace" "$mapping" "$root_container"

    # Phase 2: Apply layouts to all containers
    # Done separately to prevent layout changes from affecting joins
    log "Phase 2: Applying container layouts..."
    apply_layouts "$root_container" "$mapping" "$target_workspace" "true"

    # Step 8a: Re-apply root layout after Phase 2 (safety net)
    log "Re-applying root layout after Phase 2: $root_layout"
    set_root_layout "$root_layout" "$target_workspace" "$mapping" "$root_container"

    log "=========================================="
    log "Layout recreation complete!"
    log "=========================================="

    # apply-verify: run the structural diff after apply
    if [[ "$subcommand" == "apply-verify" ]]; then
        log ""
        log "Running post-apply verification..."
        run_verify "$target_workspace" "$json_input"
        exit $?
    fi
}

main "$@"
