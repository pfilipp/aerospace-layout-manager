[
  {
    "name": "homelab",
    "type": "workspace",
    "root-container": {
      "type": "container",
      "layout": "h_tiles",
      "orientation": "horizontal",
      "children": [
        {
          "type": "window",
          "app-bundle-id": "com.googlecode.iterm2",
          "app-name": "iTerm2",
          "title": "${PROJECT_NAME}",
          "source-workspace": "temp",
          "window-id": 1,
          "startup": "~/nix-config/modules/darwin/scripts/iterm-window.sh '${PROJECT_ITERM_CMD}'"
        },
        {
          "type": "container",
          "layout": "v_accordion",
          "orientation": "vertical",
          "children": [
            {
              "type": "window",
              "app-bundle-id": "com.microsoft.VSCode",
              "app-name": "Code",
              "title": "${PROJECT_NAME}",
              "window-id": 2,
              "startup": "code ${PROJECT_DIR}/${PROJECT_SUBDIR}"
            },
            {
              "type": "window",
              "app-bundle-id": "com.apple.dt.Xcode",
              "app-name": "Xcode",
              "title": "${PROJECT_NAME}",
              "window-id": 3,
              "startup": "open ${PROJECT_DIR}/${PROJECT_XCODEPROJ}"
            }
          ]
        },
        {
          "type": "window",
          "app-bundle-id": "com.apple.Safari",
          "app-name": "Safari",
          "title": "Home Server",
          "window-id": 4,
          "startup": "open -b com.apple.Safari"
        },
        {
          "type": "window",
          "app-bundle-id": "com.brave.Browser",
          "app-name": "Brave Browser",
          "title": "",
          "window-id": 5,
          "startup": "open -a \"Brave Browser\""
        },
        {
          "type": "window",
          "app-bundle-id": "com.tinyspeck.slackmacgap",
          "app-name": "Slack",
          "title": "",
          "window-id": 6,
          "startup": "open -a Slack"
        },
        {
          "type": "window",
          "app-bundle-id": "com.figma.Desktop",
          "app-name": "Figma",
          "title": "",
          "window-id": 7,
          "startup": "open -a Figma"
        },
        {
          "type": "window",
          "app-bundle-id": "com.anthropic.claudefordesktop",
          "app-name": "Claude",
          "title": "",
          "window-id": 8,
          "startup": "open -a Claude"
        }
      ]
    }
  }
]
